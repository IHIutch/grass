{
  "name": "ihiutch-grass",
  "description": "A Sass compiler written purely in Rust. Native speed with WASM fallback.",
  "version": "0.14.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IHIutch/grass"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "browser.js",
    "browser.d.ts",
    "workers.js",
    "workers.d.ts",
    "grass.js",
    "grass.d.ts",
    "grass_bg.wasm",
    "grass_bg.wasm.d.ts",
    "grass.*.node"
  ],
  "type": "module",
  "exports": {
    ".": {
      "node": {
        "types": "./index.d.ts",
        "default": "./index.js"
      },
      "default": {
        "types": "./browser.d.ts",
        "default": "./browser.js"
      }
    },
    "./workers": {
      "types": "./workers.d.ts",
      "default": "./workers.js"
    },
    "./grass_bg.wasm": "./grass_bg.wasm"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "keywords": [
    "scss",
    "sass",
    "css",
    "web",
    "wasm",
    "cloudflare-workers",
    "native"
  ]
}
